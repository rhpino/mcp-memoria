# mcp-memoria — environment configuration template
# Copy to /opt/mcps/memoria/.env and customize.

# ── Service ─────────────────────────────────────────────────────────
MCP_PORT=9092
MCP_LOG_LEVEL=info
MCP_LOG_FORMAT=plain  # plain | json

# ── Workspace (filesystem source of truth) ──────────────────────────
WORKSPACE_ROOT=/home/cloudops/.openclaw/workspace

# ── Identity ────────────────────────────────────────────────────────
MCP_INSTANCE_DIR=/var/lib/mcp-memoria

# ── Vector store (sqlite-vec) ───────────────────────────────────────
MCP_VEC_DB=/var/lib/mcp-memoria/vectors.db
VEC_TABLE=vec_chunks

# ── Embeddings (Stage 0 decision: RESEARCH.md) ──────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_MAX_CHARS=512
EMBEDDING_SEMAPHORE=4

# ── Index store (kb/index.json) ─────────────────────────────────────
MCP_INDEX_PATH=/var/lib/mcp-memoria/index.json

# ── Auth (Tailscale WhoIs + Bearer) ─────────────────────────────────
# Required to read tokens from /etc/flow-gateway/tokens.env
FLOW_GATEWAY_TOKENS=/etc/flow-gateway/tokens.env
TAILSCALE_WHOIS_BIN=/usr/bin/tailscale
# CGNAT Tailscale range
TAILSCALE_CIDR=100.64.0.0/10
# LAN casa via Tailscale
LAN_VPN_CIDR=10.255.255.0/24

# ── Mop-mcp migration (Q3 approach A) ───────────────────────────────
MOP_MCP_DB_ENABLED=false
MOP_MCP_DB_HOST=127.0.0.1
MOP_MCP_DB_PORT=3306
MOP_MCP_DB_USER=mop_user
MOP_MCP_DB_PASS=
MOP_MCP_DB_NAME=mop_state

# ── Bibliotecario LLM merge ─────────────────────────────────────────
# MiniMax remains optional. Vertex Gemini uses Application Default
# Credentials, not a Gemini API key:
#   gcloud auth application-default login
MINIMAX_ENABLED=false
MINIMAX_API=https://api.minimax.com/v1/text/chatcompletion_v2
MINIMAX_KEY=
MINIMAX_MODEL=minimax-m3

VERTEX_GEMINI_ENABLED=true
VERTEX_PROJECT=jesus-495023
VERTEX_LOCATION=us-central1
GCLOUD_BIN=/snap/bin/gcloud
GEMINI_MODEL=gemini-2.5-pro
